        <mxCell id="chapter1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=16;align=center;verticalAlign=top;fillColor=#D4E1F5;strokeColor=#000000;strokeWidth=2;spacingTop=10;" value="&lt;div style=&quot;&quot;&gt;&lt;b style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 24px;&quot;&gt;第一章&lt;/font&gt;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;b style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 24px;&quot;&gt;绪论&lt;/font&gt;&lt;/b&gt;&lt;/div&gt;" vertex="1">
